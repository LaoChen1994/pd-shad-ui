{
  "name": "pd-ui-monorepo",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter pd-web-demo run dev",
    "build": "pnpm --filter pd-web-demo run build",
    "build:ui": "pnpm --filter pd-shad-ui run build",
    "test:ui": "pnpm --filter pd-shad-ui run test",
    "changeset": "changeset",
    "version:ui": "changeset version && pnpm install",
    "release:ui": "pnpm build:ui && pnpm test:ui && changeset publish",
    "lint": "eslint .",
    "preview": "pnpm --filter pd-web-demo run preview"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.0",
    "vitest-axe": "^0.1.0"
  }
}

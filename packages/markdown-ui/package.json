{
  "name": "pd-markdown-ui",
  "version": "1.3.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/LaoChen1994/pd-ui.git",
    "directory": "packages/markdown-ui"
  },
  "homepage": "https://github.com/LaoChen1994/pd-ui/tree/main/packages/markdown-ui",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tailwindcss -c tailwind.config.js -i ../ui/src/globals.css -o dist/styles.css --minify",
    "dev": "tsup --watch",
    "storybook": "pnpm run storybook:react",
    "storybook:react": "storybook dev -p 6011",
    "storybook:vue": "storybook dev -c .storybook-vue -p 6012",
    "build-storybook": "pnpm run build-storybook:react",
    "build-storybook:react": "storybook build -o storybook-static-react",
    "build-storybook:vue": "storybook build -c .storybook-vue -o storybook-static-vue",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "katex": "^0.16.39",
    "lucide-vue-next": "^0.477.0",
    "pd-shad-ui": "workspace:*",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.5.8",
    "@storybook/addon-essentials": "8.5.8",
    "@storybook/addon-interactions": "8.5.8",
    "@storybook/addon-themes": "^8.5.8",
    "@storybook/react": "8.5.8",
    "@storybook/react-vite": "8.5.8",
    "@storybook/vue3": "8.5.8",
    "@storybook/vue3-vite": "8.5.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/katex": "^0.16.8",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "react-markdown": "^10.1.0",
    "storybook": "^8.5.8",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}

      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.mjs",
      "require": "./dist/lib/utils.cjs"
    },
    "./components/ui/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.mjs",
      "require": "./dist/components/ui/*.cjs"
    }
  },
  "files": [
    "dist"
